generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AttendanceAudience {
  PARENT
  COACH
}

model User {
  id          String      @id @default(cuid())
  lineUserId  String      @unique
  displayName String
  pictureUrl  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  created     Match[]     @relation("MatchCreatedBy")
  updated     Match[]     @relation("MatchUpdatedBy")
  schedulesCreated ScheduleEntry[] @relation("ScheduleCreatedBy")
  schedulesUpdated ScheduleEntry[] @relation("ScheduleUpdatedBy")
  attendances      Attendance[]
  dutiesAssigned   DutyAssignment[] @relation("DutyAssignedTo")
  dutiesDecided    DutyAssignment[] @relation("DutyDecidedBy")
  carpoolPreferences CarpoolPreference[]
}

model Player {
  id        String   @id @default(cuid())
  number    String
  name      String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id            String       @id @default(cuid())
  tournament    String
  title         String
  opponent      String
  matchDate     DateTime
  tags          String[]
  periodMode    String
  pkMode        String
  homeScore     Int
  awayScore     Int
  homePkScore   Int          @default(0)
  awayPkScore   Int          @default(0)
  duration      String
  outcome       String
  createdById   String
  updatedById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     User         @relation("MatchCreatedBy", fields: [createdById], references: [id])
  updatedBy     User         @relation("MatchUpdatedBy", fields: [updatedById], references: [id])
  goals         GoalEvent[]
}

model GoalEvent {
  id        String   @id @default(cuid())
  matchId    String
  side      String
  player    String?
  period    String
  time      String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model ScheduleEntry {
  id             String         @id @default(cuid())
  eventDate      DateTime
  tags           String[]
  editedFields   String[]       @default([])
  startTime      String
  endTime        String
  location       String
  content        String
  dutyLabel      String?
  isMatch        Boolean        @default(false)
  note           String?
  createdById    String
  updatedById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdBy      User           @relation("ScheduleCreatedBy", fields: [createdById], references: [id])
  updatedBy      User           @relation("ScheduleUpdatedBy", fields: [updatedById], references: [id])
  attendances    Attendance[]
  dutyAssignment DutyAssignment?
  carpoolPreferences CarpoolPreference[]
}

model Attendance {
  id              String        @id @default(cuid())
  scheduleEntryId String
  userId          String
  audience        AttendanceAudience @default(PARENT)
  status          String
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleEntryId, userId, audience])
}

model DutyAssignment {
  id              String        @id @default(cuid())
  scheduleEntryId String        @unique
  assignedUserId  String?
  decidedById     String?
  note            String?
  decidedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  assignedUser    User?         @relation("DutyAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  decidedBy       User?         @relation("DutyDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
}

model CarpoolPreference {
  id              String        @id @default(cuid())
  scheduleEntryId String
  userId          String
  choice          String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleEntryId, userId])
}

model PlayerPromotionRun {
  id        String   @id @default(cuid())
  year      Int      @unique
  appliedAt DateTime @default(now())
}
